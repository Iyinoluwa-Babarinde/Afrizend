generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String         @id @default(uuid())
  name                      String?
  email                     String?        @unique
  password_hash             String?
  role                      String?
  wallet_address            String?
  trust_score               Float?         @default(0)
  balance                   Float?         @default(0)
  company                   String?
  bio                       String?
  skills                    String?
  hourly_rate               Float?
  currency                  String?        @default("NGN")
  virtual_account_number    String?
  virtual_bank_name         String?
  virtual_account_reference String?
  created_at                DateTime?      @default(now())

  activities                UserActivity[]
  jobs                      Job[]          @relation("EmployerJobs")
  applications              Application[]
  wallet_transactions_from  WalletTransaction[] @relation("FromUser")
  wallet_transactions_to    WalletTransaction[] @relation("ToUser")
}

model UserActivity {
  id          String    @id @default(uuid())
  user_id     String?
  action_type String?
  details     String?
  created_at  DateTime? @default(now())

  user        User?     @relation(fields: [user_id], references: [id])

  @@map("user_activities")
}

model Job {
  id          String    @id @default(uuid())
  employer_id String?
  title       String?
  description String?
  budget      Float?
  currency    String?
  deadline    String?
  skills      String?
  status      String?   @default("open")
  freelancer_id String?
  freelancer_name String?
  created_at  DateTime? @default(now())

  employer    User?     @relation("EmployerJobs", fields: [employer_id], references: [id])
  milestones  Milestone[]
  matches     Match[]
  chat_messages ChatMessage[]
  contracts   Contract[]
  applications Application[]

  @@map("jobs")
}

model Milestone {
  id          String    @id @default(uuid())
  job_id      String?
  title       String?
  description String?
  amount      Float?
  status      String?   @default("pending")
  deliverables String?
  acceptance_criteria String?

  job         Job?      @relation(fields: [job_id], references: [id])
  deliverables_list Deliverable[]

  @@map("milestones")
}

model Match {
  id              String    @id @default(uuid())
  job_id          String?
  freelancer_id   String?
  freelancer_name String?
  score           Float?
  reasoning       String?
  status          String?   @default("matched")

  job             Job?      @relation(fields: [job_id], references: [id])

  @@map("matches")
}

model ChatMessage {
  id          String    @id @default(uuid())
  job_id      String?
  sender_id   String?
  content     String?
  is_terms    Boolean?  @default(false)
  created_at  DateTime? @default(now())

  job         Job?      @relation(fields: [job_id], references: [id])

  @@map("chat_messages")
}

model Contract {
  id            String    @id @default(uuid())
  job_id        String?
  employer_id   String?
  freelancer_id String?
  escrow_status String?   @default("pending")
  agreed_amount Float?

  job           Job?      @relation(fields: [job_id], references: [id])

  @@map("contracts")
}

model Deliverable {
  id                     String    @id @default(uuid())
  milestone_id           String?
  freelancer_id          String?
  content                String?
  ai_verification_score  Float?
  ai_verification_report String?
  status                 String?   @default("submitted")

  milestone              Milestone? @relation(fields: [milestone_id], references: [id])

  @@map("deliverables")
}

model Application {
  id            String    @id @default(uuid())
  job_id        String?
  freelancer_id String?
  cover_note    String?
  status        String?   @default("pending")
  created_at    DateTime? @default(now())

  job           Job?      @relation(fields: [job_id], references: [id])
  freelancer    User?     @relation(fields: [freelancer_id], references: [id])

  @@map("applications")
}

model WalletTransaction {
  id           String    @id @default(uuid())
  from_user_id String?
  to_user_id   String?
  amount       Float?
  type         String?
  description  String?
  job_id       String?
  milestone_id String?
  created_at   DateTime? @default(now())

  from_user    User?     @relation("FromUser", fields: [from_user_id], references: [id])
  to_user      User?     @relation("ToUser", fields: [to_user_id], references: [id])

  @@map("wallet_transactions")
}
